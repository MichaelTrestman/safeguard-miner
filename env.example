NETWORK=test
NETUID=444
WALLET_NAME=myminer
HOTKEY_NAME=default
HOST=0.0.0.0
PORT=8090

# Chutes API key for the attacker LLM and the self-scoring judge.
# Required — without it the prober and scorer return empty/zero.
CHUTES_API_KEY=cpk_...

# Public URL committed to chain so validators can reach this miner.
# In local dev this is auto-detected; in k8s set it to the
# LoadBalancer's external IP after the Service is created.
# MINER_EXTERNAL_ENDPOINT=http://YOUR_LB_IP:8090

# Optional model overrides (default: DeepSeek-V3)
# MINER_ATTACK_MODEL=deepseek-ai/DeepSeek-V3
# MINER_JUDGE_MODEL=deepseek-ai/DeepSeek-V3
# MINER_MAX_TURNS=6

# Minimum self-score reported for completed probes. The miner is a
# lead — claiming 0 hides signal from the audit. Default 0.3.
# MINER_SCORE_FLOOR=0.3

# Enable HITL (human-in-the-loop) labeling role. Default true.
# HITL_ENABLED=true

# Optional cap on concurrent in-flight probes. 0 = no cap.
# Set this if Chutes rate-limits under concurrent load.
# MAX_CONCURRENT_PROBES=0

# HTTP Basic Auth for the operator dashboard. If BOTH are unset,
# the dashboard is open (suitable for local dev). In production,
# always set both.
# DASHBOARD_ADMIN_USER=admin
# DASHBOARD_ADMIN_PASSWORD=changeme
